{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/generate.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/voice", "destination": "/api/voice" },
    { "source": "/design-system", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
