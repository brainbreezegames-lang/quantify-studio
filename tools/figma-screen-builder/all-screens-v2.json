  {
    "name": "02. Connection Settings",
    "template": "top_nav_screen",
    "width": 390,
    "height": 844,
    "surface": "surface",
    "regions": {
      "nav": {
        "type": "component",
        "ref": "cmp.navigationbar",
        "variant": { "Content": "Title" },
        "slots": { "title": "Connection" }
      },
      "content": {
        "type": "scroll_section",
        "children": [
          {
            "type": "section",
            "label": "SERVER",
            "padding": "screen-h",
            "spacing": "md",
            "children": [
              {
                "type": "component",
                "ref": "cmp.textbox",
                "variant": { "Type": "Outlined", "State": "Enabled", "Label": "True", "Populated": "True", "Placeholder": "False", "Multiline": "False" },
                "slots": { "label": "Remote server", "value": "myinstance.mycompany.com" },
                "stretch": true
              },
              { "type": "spacer", "size": "lg" },
              {
                "type": "setting_row",
                "slots": { "label": "Protocol", "value": "https://" },
                "valueStyle": "accent"
              },
              { "type": "component", "ref": "cmp.divider", "variant": { "Length": "Full" }, "stretch": true },
              {
                "type": "setting_row",
                "slots": { "label": "Use SSL" },
                "trailing": {
                  "type": "component",
                  "ref": "cmp.toggleswitch",
                  "variant": { "State": "Enabled", "Selected": "True" }
                }
              }
            ]
          },
          { "type": "spacer", "size": "xl" },
          {
            "type": "action_section",
            "padding": "screen-h",
            "spacing": "lg",
            "children": [
              {
                "type": "component",
                "ref": "cmp.button",
                "variant": { "Style": "Filled", "State": "Enabled", "Icon": "False" },
                "slots": { "label": "Test Connection" },
                "stretch": true
              },
              {
                "type": "component",
                "ref": "tpl.error_banner",
                "slots": {
                  "title": "Connection failed",
                  "message": "Unable to reach server. Check your network and server address."
                }
              }
            ]
          }
        ]
      }
    }
  },

  {
    "name": "02b. Connection - Success",
    "extends": "02. Connection Settings",
    "state": "success",
    "overrides": {
      "content.action_section.1": {
        "type": "component",
        "ref": "tpl.success_banner",
        "slots": {
          "title": "Connected successfully",
          "message": "Server is reachable. You can now sign in."
        }
      }
    }
  },

