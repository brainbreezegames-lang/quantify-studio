  {
    "name": "01. Login",
    "template": "auth_screen",
    "width": 390,
    "height": 844,
    "surface": "surface",
    "regions": {
      "brand": {
        "type": "brand_header",
        "surface": "primary",
        "height": 220,
        "slots": {
          "monogram": "Q",
          "title": "Quantify",
          "subtitle": "Scaffolding Management"
        }
      },
      "content": {
        "type": "form_section",
        "spacing": "lg",
        "padding": "screen-h",
        "children": [
          {
            "type": "component",
            "ref": "cmp.textbox",
            "variant": { "Type": "Outlined", "State": "Enabled", "Label": "True", "Populated": "False", "Placeholder": "True", "Multiline": "False" },
            "slots": { "label": "Username" },
            "stretch": true
          },
          {
            "type": "component",
            "ref": "cmp.passwordbox",
            "variant": { "Type": "Outlined", "Leading": "None" },
            "slots": { "label": "Password" },
            "stretch": true
          },
          { "type": "spacer", "size": "sm" },
          {
            "type": "component",
            "ref": "cmp.button",
            "variant": { "Style": "Filled", "State": "Enabled", "Icon": "False" },
            "slots": { "label": "Sign In" },
            "stretch": true
          },
          {
            "type": "component",
            "ref": "cmp.button",
            "variant": { "Style": "Text", "State": "Enabled", "Icon": "False" },
            "slots": { "label": "Connection Settings" },
            "stretch": true
          }
        ]
      },
      "status": {
        "type": "status_bar",
        "slots": { "text": "Connected to mycompany.quantifycloud.com" }
      },
      "footer": {
        "type": "app_footer",
        "slots": { "version": "v1.2.3", "copyright": "2008-2026 Avontus Software Corp." }
      }
    }
  },

