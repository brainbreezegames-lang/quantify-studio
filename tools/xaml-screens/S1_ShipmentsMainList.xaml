        <x:String x:Key="Icon_More_Vert">F1 M 2 4 C 3.1 4 4 3.1 4 2 C 4 0.9 3.1 0 2 0 C 0.9 0 0 0.9 0 2 C 0 3.1 0.9 4 2 4 Z M 2 6 C 0.9 6 0 6.9 0 8 C 0 9.1 0.9 10 2 10 C 3.1 10 4 9.1 4 8 C 4 6.9 3.1 6 2 6 Z M 2 12 C 0.9 12 0 12.9 0 14 C 0 15.1 0.9 16 2 16 C 3.1 16 4 15.1 4 14 C 4 12.9 3.1 12 2 12 Z</x:String>
        <x:String x:Key="Icon_Check">F1 M 4.19 7.93 L 1.06 4.81 L 0 5.86 L 4.19 10.06 L 13.19 1.06 L 12.14 0 L 4.19 7.93 Z</x:String>
        <x:String x:Key="Icon_Local_Shipping">F1 M 14.25 3 L 12 3 L 12 0 L 1.5 0 C 0.675 0 0 0.675 0 1.5 L 0 9.75 L 1.5 9.75 C 1.5 10.995 2.505 12 3.75 12 C 4.995 12 6 10.995 6 9.75 L 10.5 9.75 C 10.5 10.995 11.505 12 12.75 12 C 13.995 12 15 10.995 15 9.75 L 16.5 9.75 L 16.5 6 L 14.25 3 Z M 3.75 10.875 C 3.128 10.875 2.625 10.372 2.625 9.75 C 2.625 9.128 3.128 8.625 3.75 8.625 C 4.372 8.625 4.875 9.128 4.875 9.75 C 4.875 10.372 4.372 10.875 3.75 10.875 Z M 13.875 4.125 L 15.345 6 L 12 6 L 12 4.125 L 13.875 4.125 Z M 12.75 10.875 C 12.128 10.875 11.625 10.372 11.625 9.75 C 11.625 9.128 12.128 8.625 12.75 8.625 C 13.372 8.625 13.875 9.128 13.875 9.75 C 13.875 10.372 13.372 10.875 12.75 10.875 Z</x:String>
        <x:String x:Key="Icon_Arrow_Upward">F1 M 0 6 L 1.06 7.06 L 5.25 2.87 L 5.25 12 L 6.75 12 L 6.75 2.87 L 10.93 7.07 L 12 6 L 6 0 L 0 6 Z</x:String>
        <x:String x:Key="Icon_Play_Arrow">F1 M 0 0 L 0 10.5 L 8.25 5.25 L 0 0 Z</x:String>
        <x:String x:Key="Icon_Close">F1 M 10.5 1.06 L 9.44 0 L 5.25 4.19 L 1.06 0 L 0 1.06 L 4.19 5.25 L 0 9.44 L 1.06 10.5 L 5.25 6.31 L 9.44 10.5 L 10.5 9.44 L 6.31 5.25 L 10.5 1.06 Z</x:String>
        <x:String x:Key="Icon_Sync">F1 M 6 2.25 L 6 0 L 3 3 L 6 6 L 6 3.75 C 8.48 3.75 10.5 5.77 10.5 8.25 C 10.5 9.01 10.31 9.73 9.97 10.35 L 11.07 11.45 C 11.66 10.52 12 9.43 12 8.25 C 12 4.93 9.32 2.25 6 2.25 Z M 6 12.75 C 3.52 12.75 1.5 10.73 1.5 8.25 C 1.5 7.49 1.69 6.77 2.02 6.15 L 0.93 5.05 C 0.34 5.98 0 7.07 0 8.25 C 0 11.57 2.68 14.25 6 14.25 L 6 16.5 L 9 13.5 L 6 10.5 L 6 12.75 Z</x:String>
        <x:String x:Key="Icon_Add">F1 M 18.67 10.67 L 10.67 10.67 L 10.67 18.67 L 8 18.67 L 8 10.67 L 0 10.67 L 0 8 L 8 8 L 8 0 L 10.67 0 L 10.67 8 L 18.67 8 L 18.67 10.67 Z</x:String>
        <x:String x:Key="Icon_Description">F1 M 10 0 L 2 0 C 0.9 0 0.01 0.9 0.01 2 L 0 18 C 0 19.1 0.89 20 1.99 20 L 14 20 C 15.1 20 16 19.1 16 18 L 16 6 L 10 0 Z M 12 16 L 4 16 L 4 14 L 12 14 L 12 16 Z M 12 12 L 4 12 L 4 10 L 12 10 L 12 12 Z M 9 7 L 9 1.5 L 14.5 7 L 9 7 Z</x:String>
        <x:String x:Key="Icon_Search">F1 M 12.5 11 L 11.71 11 L 11.43 10.73 C 12.41 9.59 13 8.11 13 6.5 C 13 2.91 10.09 0 6.5 0 C 2.91 0 0 2.91 0 6.5 C 0 10.09 2.91 13 6.5 13 C 8.11 13 9.59 12.41 10.73 11.43 L 11 11.71 L 11 12.5 L 16 17.49 L 17.49 16 L 12.5 11 Z M 6.5 11 C 4.01 11 2 8.99 2 6.5 C 2 4.01 4.01 2 6.5 2 C 8.99 2 11 4.01 11 6.5 C 11 8.99 8.99 11 6.5 11 Z</x:String>
        <x:String x:Key="Icon_Settings">F1 M 16.48 10.54 C 16.52 10.24 16.54 9.93 16.54 9.6 C 16.54 9.28 16.52 8.96 16.47 8.66 L 18.5 7.08 C 18.68 6.94 18.73 6.67 18.62 6.47 L 16.7 3.15 C 16.58 2.93 16.33 2.86 16.11 2.93 L 13.72 3.89 C 13.22 3.51 12.69 3.19 12.1 2.95 L 11.74 0.41 C 11.7 0.17 11.5 0 11.26 0 L 7.42 0 C 7.18 0 6.99 0.17 6.95 0.41 L 6.59 2.95 C 6 3.19 5.46 3.52 4.97 3.89 L 2.58 2.93 C 2.36 2.85 2.11 2.93 1.99 3.15 L 0.08 6.47 C -0.04 6.68 0 6.94 0.2 7.08 L 2.23 8.66 C 2.18 8.96 2.14 9.29 2.14 9.6 C 2.14 9.91 2.16 10.24 2.21 10.54 L 0.18 12.12 C 0 12.26 -0.05 12.53 0.06 12.73 L 1.98 16.05 C 2.1 16.27 2.35 16.34 2.57 16.27 L 4.96 15.31 C 5.46 15.69 5.99 16.01 6.58 16.25 L 6.94 18.79 C 6.99 19.03 7.18 19.2 7.42 19.2 L 11.26 19.2 C 11.5 19.2 11.7 19.03 11.73 18.79 L 12.09 16.25 C 12.68 16.01 13.22 15.69 13.71 15.31 L 16.1 16.27 C 16.32 16.35 16.57 16.27 16.69 16.05 L 18.61 12.73 C 18.73 12.51 18.68 12.26 18.49 12.12 L 16.48 10.54 Z M 9.34 13.2 C 7.36 13.2 5.74 11.58 5.74 9.6 C 5.74 7.62 7.36 6 9.34 6 C 11.32 6 12.94 7.62 12.94 9.6 C 12.94 11.58 11.32 13.2 9.34 13.2 Z</x:String>
    </Page.Resources>


    <Grid toolkit:VisibleBoundsPadding.PaddingMask="All">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- NavBar -->
            <RowDefinition Height="Auto" />  <!-- Divider -->
            <RowDefinition Height="Auto" />  <!-- Location Bar -->
            <RowDefinition Height="Auto" />  <!-- Divider -->
            <RowDefinition Height="*" />     <!-- Scrollable content -->
            <RowDefinition Height="Auto" />  <!-- Bottom Tabs -->
        </Grid.RowDefinitions>


        <!-- ═══════════════════════════════════════ -->
        <!-- NAV BAR                                 -->
        <!-- ═══════════════════════════════════════ -->

        <Grid Grid.Row="0" Height="56" Padding="16,12"
              Background="White">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="4"
                    VerticalAlignment="Center"
                    Tapped="OnMenuTapped">
                <PathIcon Data="{StaticResource Icon_Menu}"
                          Foreground="#111111" />
            </Border>

            <TextBlock Grid.Column="1" Text="Shipments"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="#111111"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center" />

            <Border Grid.Column="2" Padding="4"
                    VerticalAlignment="Center"
                    Tapped="OnMoreTapped">
                <PathIcon Data="{StaticResource Icon_More_Vert}"
                          Foreground="#111111" />
            </Border>
        </Grid>


        <!-- Divider -->
        <Border Grid.Row="1" Height="1" Background="#E0E0E0" />


        <!-- ═══════════════════════════════════════ -->
        <!-- LOCATION BAR                            -->
        <!-- ═══════════════════════════════════════ -->

        <Grid Grid.Row="2" Padding="24,16"
              Background="White">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="LOCATION"
                           FontSize="12" FontWeight="Medium"
                           Foreground="#777777" />
                <!-- DEV: Bind to SelectedBranch.Name -->
                <TextBlock Text="New York (Branch Office)"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#111111" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Change"
                    FontSize="14" FontWeight="Medium"
                    Foreground="#0A3EFF"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    Tapped="OnChangeLocationTapped" />
        </Grid>


        <!-- Divider -->
        <Border Grid.Row="3" Height="1" Background="#E0E0E0" />


        <!-- ═══════════════════════════════════════ -->
        <!-- SCROLLABLE CONTENT                      -->
        <!-- ═══════════════════════════════════════ -->

        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Spacing="0">

                <!-- Spacer -->
                <Border Height="20" />


                <!-- List Header -->
                <Grid Padding="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- DEV: Bind to ShipmentCount -->
                    <TextBlock Grid.Column="0"
                               Text="6 shipments"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#111111"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="1"
                            Content="Filter &amp; Sort"
                            FontSize="14" FontWeight="Medium"
                            Foreground="#0A3EFF"
                            Background="Transparent"
                            BorderBrush="#B5B5B5"
                            BorderThickness="1"
                            CornerRadius="100"
                            Padding="24,10"
                            Tapped="OnFilterSortTapped" />
                </Grid>


                <!-- Sync info -->
                <TextBlock Text="Synced 2 min ago"
                           FontSize="14" Foreground="#777777"
                           Padding="20,4" />

                <!-- Spacer -->
                <Border Height="4" />


                <!-- ═══════════════════════════════ -->
                <!-- SHIPMENT LIST                   -->
                <!-- DEV: This becomes a ListView    -->
                <!-- with ItemTemplate               -->
                <!-- ═══════════════════════════════ -->

                <StackPanel Spacing="4">


                    <!-- ─── Row 1: Return - Completed ─── -->
                    <Border Background="White" Padding="20">
                        <StackPanel>

                            <!-- Top row: icon + ID + date -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="100"
                                        Background="#E8F5E9"
                                        Margin="0,0,12,0">
                                    <PathIcon Data="{StaticResource Icon_Check}"
                                              Foreground="#2E7D32"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="RET-00756"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" Text="Jul 5"
                                           FontSize="14" Foreground="#777777"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="8" />

                            <!-- Customer -->
                            <TextBlock Text="Titan Apex Industrial Services"
                                       FontSize="16" Foreground="#555555" />

                            <Border Height="10" />

                            <!-- Bottom row: pieces + badge -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="274 pcs  ·  5,723 lbs"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <Border Grid.Column="1"
                                        Background="#E8F5E9"
                                        Padding="12,5">
                                    <TextBlock Text="RETURNED"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#2E7D32" />
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>


                    <!-- ─── Row 2: Delivery - On Rent ─── -->
                    <Border Background="White" Padding="20">
                        <StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="100"
                                        Background="#E8EEFF"
                                        Margin="0,0,12,0">
                                    <PathIcon Data="{StaticResource Icon_Local_Shipping}"
                                              Foreground="#0A3EFF"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="DEL-00802"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" Text="Jul 9"
                                           FontSize="14" Foreground="#777777"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="8" />

                            <TextBlock Text="BlueRidge Fabrication &amp; Erection"
                                       FontSize="16" Foreground="#555555" />

                            <Border Height="10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="612 pcs  ·  2,874 lbs"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <Border Grid.Column="1"
                                        Background="#E8EEFF"
                                        Padding="12,5">
                                    <TextBlock Text="ON RENT"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#0A3EFF" />
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>


                    <!-- ─── Row 3: To Be Received (yellow highlight) ─── -->
                    <Border Background="#FFF8E1" Padding="20">
                        <StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="100"
                                        Background="#FFF3CD"
                                        Margin="0,0,12,0">
                                    <PathIcon Data="{StaticResource Icon_Arrow_Upward}"
                                              Foreground="#F57F17"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="DEL-00791"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" Text="Jul 11"
                                           FontSize="14" Foreground="#777777"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="8" />

                            <TextBlock Text="Titan Apex Industrial Services"
                                       FontSize="16" Foreground="#555555" />

                            <Border Height="10" />

                            <!-- No badge — action-needed text instead -->
                            <TextBlock Text="589 pcs  ·  Needs your count"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#F57F17" />

                        </StackPanel>
                    </Border>


                    <!-- ─── Row 4: Reservation ─── -->
                    <Border Background="White" Padding="20">
                        <StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="100"
                                        Background="#F2F2F2"
                                        Margin="0,0,12,0">
                                    <PathIcon Data="{StaticResource Icon_Play_Arrow}"
                                              Foreground="#555555"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="DEL-00747"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" Text="Jul 15"
                                           FontSize="14" Foreground="#777777"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="8" />

                            <TextBlock Text="Ironcrest Solutions Group"
                                       FontSize="16" Foreground="#555555" />

                            <Border Height="10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="498 pcs  ·  3,415 lbs"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <Border Grid.Column="1"
                                        Background="#F2F2F2"
                                        Padding="12,5">
                                    <TextBlock Text="RESERVED"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#555555" />
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>


                    <!-- ─── Row 5: Discrepancy (red highlight) ─── -->
                    <Border Background="#FDECEA" Padding="20">
                        <StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="100"
                                        Background="#FDECEA"
                                        BorderBrush="#D32F2F"
                                        BorderThickness="2"
                                        Margin="0,0,12,0">
                                    <PathIcon Data="{StaticResource Icon_Close}"
                                              Foreground="#D32F2F"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="RET-00829"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" Text="Jul 24"
                                           FontSize="14" Foreground="#777777"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="8" />

                            <TextBlock Text="Vanguard Plant Systems"
                                       FontSize="16" Foreground="#555555" />

                            <Border Height="10" />

                            <!-- No badge — error text instead -->
                            <TextBlock Text="583 pcs  ·  Count mismatch (−12)"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#D32F2F" />

                        </StackPanel>
                    </Border>


                    <!-- ─── Row 6: Pre-Return ─── -->
                    <Border Background="White" Padding="20">
                        <StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="100"
                                        Background="#FFF3CD"
                                        Margin="0,0,12,0">
                                    <PathIcon Data="{StaticResource Icon_Sync}"
                                              Foreground="#F57F17"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="PRE-00415"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#111111"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" Text="Jul 28"
                                           FontSize="14" Foreground="#777777"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="8" />

                            <TextBlock Text="Meridian Construction Partners"
                                       FontSize="16" Foreground="#555555" />

                            <Border Height="10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="312 pcs  ·  Pickup Aug 2"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="#F57F17"
                                           VerticalAlignment="Center" />

                                <Border Grid.Column="1"
                                        Background="#FFF3CD"
                                        Padding="12,5">
                                    <TextBlock Text="PRE-RETURN"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#F57F17" />
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>


                </StackPanel>

                <!-- Bottom padding so FAB doesn't cover last item -->
                <Border Height="80" />

            </StackPanel>
        </ScrollViewer>


        <!-- ═══════════════════════════════════════ -->
        <!-- FAB (Floating Action Button)            -->
        <!-- ═══════════════════════════════════════ -->

        <Border Grid.Row="4"
                Width="56" Height="56"
                CornerRadius="16"
                Background="#0A3EFF"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                Tapped="OnAddShipmentTapped">
            <PathIcon Data="{StaticResource Icon_Add}"
                      Foreground="White"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
        </Border>


        <!-- ═══════════════════════════════════════ -->
        <!-- BOTTOM TABS                             -->
        <!-- ═══════════════════════════════════════ -->

        <Grid Grid.Row="5" Height="72"
              Background="White"
              Padding="20,8,20,16">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Tab 1: Shipments (active) -->
            <StackPanel Grid.Column="0" Spacing="4"
                        HorizontalAlignment="Center"
                        Tapped="OnShipmentsTapped">
                <PathIcon Data="{StaticResource Icon_Local_Shipping}"
                          Foreground="#0A3EFF"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Shipments"
                           FontSize="14" FontWeight="Medium"
                           Foreground="#0A3EFF"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Tab 2: Requests -->
            <StackPanel Grid.Column="1" Spacing="4"
                        HorizontalAlignment="Center"
                        Tapped="OnRequestsTapped">
                <PathIcon Data="{StaticResource Icon_Description}"
                          Foreground="#777777"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Requests"
                           FontSize="14"
                           Foreground="#777777"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Tab 3: Products -->
            <StackPanel Grid.Column="2" Spacing="4"
                        HorizontalAlignment="Center"
                        Tapped="OnProductsTapped">
                <PathIcon Data="{StaticResource Icon_Search}"
                          Foreground="#777777"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Products"
                           FontSize="14"
                           Foreground="#777777"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Tab 4: Settings -->
            <StackPanel Grid.Column="3" Spacing="4"
                        HorizontalAlignment="Center"
                        Tapped="OnSettingsTapped">
                <PathIcon Data="{StaticResource Icon_Settings}"
                          Foreground="#777777"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Settings"
                           FontSize="14"
                           Foreground="#777777"
                           HorizontalAlignment="Center" />
            </StackPanel>

        </Grid>

    </Grid>

</Page>
